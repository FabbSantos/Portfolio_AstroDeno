---
const year = new Date().getFullYear();
---

<footer class='site-footer'>
	<div>
		© {year} · <b>Fabrício Bahiense</b> · <span data-i18n='footer.location'>Rio de Janeiro, BR</span>
	</div>
	<div class='links'>
		<a href='/about' data-i18n='nav.about'>About</a>
		<a href='/work' data-i18n='nav.work'>Work</a>
		<a href='/templates' data-i18n='nav.templates'>Templates</a>
		<a href='mailto:contato@fabbahiense.dev'>Email</a>
	</div>
</footer>

<style>
	.site-footer {
		max-width: var(--maxw);
		margin: 0 auto;
		padding: 32px;
		border-top: 1px solid var(--rule);
		display: flex;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 14px;
		font-size: 13px;
		color: var(--ink-3);
	}
	.site-footer b {
		color: var(--ink);
		font-weight: 600;
	}
	.site-footer a {
		color: var(--ink-2);
		transition: color 0.2s;
	}
	.site-footer a:hover {
		color: var(--accent);
	}
	.links {
		display: flex;
		gap: 24px;
		flex-wrap: wrap;
	}
</style>
