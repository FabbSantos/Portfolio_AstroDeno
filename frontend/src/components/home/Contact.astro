</section>

<style>
	.contact {
		padding: 120px 32px;
		text-align: center;
	}
	.contact h2 {
		font-size: clamp(48px, 7vw, 88px);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1.02;
		max-width: 18ch;
		margin: 0 auto;
	}
	.contact .sub {
		margin: 20px auto 48px;
		font-size: 18px;
		color: var(--ink-2);
		max-width: 50ch;
		line-height: 1.5;
	}

	/* Form */
	.form {
		max-width: 560px;
		margin: 0 auto;
		text-align: left;
		display: flex;
		flex-direction: column;
		gap: 18px;
	}
	.form .row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 18px;
	}
	.field {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
	.field .eyebrow {
		display: block;
	}
	.field input,
	.field select,
	.field textarea {
		font: inherit;
		font-family: var(--sans);
		padding: 12px 14px;
		border: 1px solid var(--rule-2);
		background: var(--bg-3);
		color: var(--ink);
		border-radius: 10px;
		transition:
			border-color 0.2s,
			box-shadow 0.2s;
		width: 100%;
	}
	.field textarea {
		resize: vertical;
		min-height: 120px;
	}
	.field input:focus,
	.field select:focus,
	.field textarea:focus {
		outline: none;
		border-color: var(--accent);
		box-shadow: 0 0 0 4px var(--accent-soft);
	}
	.form button {
		align-self: flex-start;
		margin-top: 6px;
	}
	.form button:disabled {
		opacity: 0.6;
		cursor: progress;
	}

	.form-status {
		margin: 0;
		min-height: 1.2em;
		font-family: var(--mono);
		font-size: 13px;
		color: var(--ink-3);
		transition: color 0.25s;
	}
	.form-status.is-sending { color: var(--ink-2); }
	.form-status.is-ok { color: #16a34a; }
	.form-status.is-err { color: var(--accent); }

	.or {
		margin-top: 32px;
		color: var(--ink-3);
		font-size: 14px;
	}
	.or .email {
		font-family: var(--mono);
		font-weight: 600;
		color: var(--accent);
		margin-left: 6px;
	}
	.or .email:hover {
		text-decoration: underline;
	}

	.social {
		list-style: none;
		margin: 24px 0 0;
		padding: 0;
		display: flex;
		justify-content: center;
		gap: 20px;
	}

	/* Same .box + shine ::before from the 2024 LinkCard. Dark icons on a
	   subtle light pill so they read on the new theme; the diagonal shine
	   sweeps across every 1s like before. */
	.box {
		position: relative;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--ink);
		background: var(--bg-3);
		border: 1px solid var(--rule);
		overflow: hidden;
		transition: color 0.25s, transform 0.25s var(--ease-out-expo),
			border-color 0.25s, box-shadow 0.25s;
	}
	.box:hover {
		color: var(--accent);
		border-color: var(--accent);
		transform: translateY(-2px);
		box-shadow: 0 8px 20px -10px var(--accent-soft);
	}
	/* Normalize all icon sizes regardless of intrinsic svg attributes — the
	   flex centering on .box only behaves consistently if every child is the
	   same size. */
	.box svg {
		width: 22px;
		height: 22px;
		display: block;
	}
	.box::before {
		content: '';
		width: 10px;
		height: 24px;
		border-radius: 20%;
		position: absolute;
		top: 2px;
		left: -20px;
		background: linear-gradient(
			to right,
			rgba(255, 255, 255, 0) 0%,
			rgba(255, 255, 255, 0) 77%,
			rgba(255, 255, 255, 0.55) 98%,
			rgba(94, 93, 93, 0) 100%
		);
		transform: skewX(-30deg);
		/* Same sweep shape from 2024 but stretched: the actual shine takes ~25%
		   of the cycle (1.5s of 6s) and the remaining 75% is idle off-screen. */
		animation: slide 6s cubic-bezier(0.41, 0.29, 0.45, 1) infinite;
		pointer-events: none;
	}

	@keyframes slide {
		0% {
			top: 10%;
			left: -8px;
			height: 0;
		}
		3% {
			top: 10%;
			left: -3px;
			height: 17px;
		}
		15% {
			left: 34px;
			height: 10px;
		}
		25% {
			left: 42px;
			top: 63%;
			height: 0;
		}
		100% {
			left: -8px;
			top: 10%;
			height: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.box::before {
			animation: none;
			opacity: 0;
		}
	}

	@media (max-width: 600px) {
		.form .row {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement | null;
	if (form) {
		// Pre-select "About a template" when arriving with ?subject=template
		const params = new URLSearchParams(window.location.search);
		const subj = params.get('subject');
		if (subj) {
			const select = form.elements.namedItem('subject') as HTMLSelectElement;
			const match = Array.from(select.options).find((o) =>
				o.value.toLowerCase().includes(subj.toLowerCase())
			);
			if (match) select.value = match.value;
		}
		const tpl = params.get('template');
		if (tpl) {
			const textarea = form.elements.namedItem('message') as HTMLTextAreaElement;
			if (!textarea.value) textarea.value = `Hi! I'd like to chat about the "${tpl}" template.\n\n`;
			const select = form.elements.namedItem('subject') as HTMLSelectElement;
			const match = Array.from(select.options).find((o) =>
				o.value.toLowerCase().includes('template')
			);
			if (match) select.value = match.value;
		}

		// Translate the textarea placeholder when locale changes (data-i18n only
		// swaps textContent — placeholders need their own listener).
		const refreshPlaceholder = () => {
			document.querySelectorAll<HTMLElement>('[data-i18n-placeholder]').forEach((el) => {
				const key = el.dataset.i18nPlaceholder!;
				import('../../i18n/i18n').then(({ t }) => el.setAttribute('placeholder', t(key)));
			});
		};
		refreshPlaceholder();
		window.addEventListener('locale-changed', refreshPlaceholder);

		const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;
		const status = document.getElementById('contact-status') as HTMLElement;

		const setStatus = async (kind: 'idle' | 'sending' | 'ok' | 'err') => {
			status.classList.remove('is-sending', 'is-ok', 'is-err');
			if (kind === 'idle') {
				status.textContent = '';
				return;
			}
			const { t } = await import('../../i18n/i18n');
			if (kind === 'sending') {
				status.classList.add('is-sending');
				status.textContent = t('contact.form.sending');
			} else if (kind === 'ok') {
				status.classList.add('is-ok');
				status.textContent = t('contact.form.success');
			} else {
				status.classList.add('is-err');
				status.textContent = t('contact.form.error');
			}
		};

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!form.reportValidity()) return;

			const data = new FormData(form);
			const payload = {
				name: String(data.get('name') || '').trim(),
				email: String(data.get('email') || '').trim(),
				subject: String(data.get('subject') || 'Contato'),
				message: String(data.get('message') || '').trim(),
			};

			submitBtn.disabled = true;
			await setStatus('sending');

			try {
				const res = await fetch('/api/contact', {
					method: 'POST',
					headers: { 'content-type': 'application/json' },
					body: JSON.stringify(payload),
				});
				const json = (await res.json().catch(() => ({}))) as { ok?: boolean };
				if (res.ok && json.ok) {
					form.reset();
					await setStatus('ok');
				} else {
					await setStatus('err');
				}
			} catch {
				await setStatus('err');
			} finally {
				submitBtn.disabled = false;
			}
		});
	}
</script>
