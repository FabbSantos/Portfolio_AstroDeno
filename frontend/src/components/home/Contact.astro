---
// Home contact — POSTs to /api/contact (Astro endpoint using Resend).
// Needs RESEND_API_KEY set in Vercel env vars + the domain verified on Resend.
---

<section class='contact' id='contato'>
	<h2 class='reveal'>
		<span data-i18n='contact.head1'>Let's</span>
		<span class='hl' data-i18n='contact.head2'>talk?</span>
	</h2>
	<p class='sub reveal d1' data-i18n='contact.sub'>
		I reply within 24 business hours. No CRM, no auto-reply — every email lands straight in my
		inbox.
	</p>

	<form class='form reveal d2' id='contact-form' novalidate>
		<div class='row'>
			<label class='field'>
				<span class='eyebrow' data-i18n='contact.form.name'>Name</span>
				<input name='name' autocomplete='name' required />
			</label>
			<label class='field'>
				<span class='eyebrow' data-i18n='contact.form.email'>Email</span>
				<input name='email' type='email' autocomplete='email' required />
			</label>
		</div>
		<label class='field'>
			<span class='eyebrow' data-i18n='contact.form.subject'>Subject</span>
			<select name='subject'>
				<option value='Just saying hi' data-i18n='contact.form.subject.hi'>Just saying hi</option>
				<option value='New project' data-i18n='contact.form.subject.project'>New project</option>
				<option value='About a template' data-i18n='contact.form.subject.template'>
					About a template
				</option>
				<option value='Other' data-i18n='contact.form.subject.other'>Other</option>
			</select>
		</label>
		<label class='field'>
			<span class='eyebrow' data-i18n='contact.form.message'>Message</span>
			<textarea
				name='message'
				rows='5'
				required
				data-i18n-placeholder='contact.form.placeholder'
				placeholder='Tell me what you have in mind…'></textarea>
		</label>
		<button type='submit' class='btn btn-primary' id='contact-submit' data-i18n='contact.form.send'>Send message</button>
		<p class='form-status' id='contact-status' role='status' aria-live='polite'></p>
	</form>

	<p class='or reveal d3'>
		<span data-i18n='contact.form.or'>or email me directly at</span>
		<a href='mailto:contato@fabbahiense.dev' class='email'>contato@fabbahiense.dev</a>
	</p>

	<ul class='social reveal d4'>
		<li>
			<a class='box menu-item' href='https://github.com/FabbSantos' target='_blank' rel='noopener' aria-label='GitHub'>
				<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
					<path fill-rule='evenodd' clip-rule='evenodd' d='M11.9958 0.599998C9.16481 0.601467 6.42662 1.60416 4.27087 3.42879C2.11513 5.25341 0.682406 7.78098 0.228891 10.5596C-0.224624 13.3381 0.330635 16.1865 1.7954 18.5953C3.26015 21.0042 5.53889 22.8165 8.22415 23.7081C8.81656 23.818 9.0397 23.4509 9.0397 23.1387C9.0397 22.8265 9.02785 21.9213 9.0239 20.9317C5.7064 21.6484 5.00538 19.5318 5.00538 19.5318C4.46431 18.1574 3.68233 17.7961 3.68233 17.7961C2.60019 17.0617 3.7633 17.0755 3.7633 17.0755C4.96194 17.1599 5.59188 18.2987 5.59188 18.2987C6.65427 20.111 8.38212 19.5868 9.06142 19.2805C9.16805 18.5127 9.47809 17.9905 9.81971 17.694C7.16966 17.3955 4.38532 16.3784 4.38532 11.835C4.3689 10.6567 4.80865 9.51714 5.6136 8.65219C5.49116 8.35375 5.08239 7.14817 5.7301 5.51064C5.7301 5.51064 6.73128 5.19256 9.01009 6.72603C10.9647 6.19454 13.027 6.19454 14.9816 6.72603C17.2584 5.19256 18.2576 5.51064 18.2576 5.51064C18.9073 7.14425 18.4985 8.34982 18.3761 8.65219C19.1836 9.51728 19.6243 10.6588 19.6063 11.8389C19.6063 16.3922 16.8161 17.3955 14.1621 17.6881C14.5886 18.0572 14.9697 18.7778 14.9697 19.8852C14.9697 21.4717 14.9559 22.7479 14.9559 23.1387C14.9559 23.4548 15.1711 23.8239 15.7754 23.7081C18.461 22.8164 20.7399 21.0038 22.2047 18.5945C23.6694 16.1852 24.2244 13.3364 23.7703 10.5576C23.3163 7.77879 21.8829 5.25119 19.7264 3.42688C17.57 1.60257 14.8311 0.600536 11.9998 0.599998H11.9958Z'></path>
				</svg>
			</a>
		</li>
		<li>
			<a class='box menu-item' href='https://www.linkedin.com/in/fabricio-b-santos/' target='_blank' rel='noopener' aria-label='LinkedIn'>
