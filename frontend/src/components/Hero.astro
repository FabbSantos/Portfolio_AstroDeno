		justify-content: center;
		align-items: center;
		min-height: 100svh;
		margin: auto;
		padding: 1rem;
		max-width: calc(100% - 20%);
		color: white;
		font-size: 20px;
		line-height: 1.6;
		scroll-behavior: smooth;
		transition: scroll-behavior 0.3s ease;
	}
	@media (max-width: 768px) {
		main {
			max-width: 100%;
		}
	}
	.chevronA {
		animation: upAndDown 2s ease-in-out infinite;
	}
	.chevron:hover path {
		fill: var(--bright-pink);
		cursor: pointer;
	}
	#hero {
		position: relative;
		/* background-image: url("../assets/DarkMode.svg");
        background-size: cover;
        background-repeat:no-repeat;
        background-color: rgba(0, 0, 0, 0.8);
        background-blend-mode: color; */
		overflow: hidden;
	}
	.svghero {
		z-index: -1;
		position: absolute;
		top: 0;
		left: 0;
		background-color: rgba(0, 0, 0, 0.8);
		/* backgr */
	}
	h1 {
		font-size: clamp(1.5rem, 8vw, 3rem);
		letter-spacing: 1px;
		font-weight: 700;
		line-height: 160%;
		text-align: center;
		max-width: 70%;
		margin-bottom: 1em;
	}
	.f {
		font-size: clamp(0.8rem, 1vw, 1.5rem);
	}
	p.fade-text span:hover,
	h1:hover {
		color: var(--bright-pink) !important;
	}
	p {
		font-size: clamp(1rem, 4vw, 1.3rem);
	}

	.astro-a {
		position: absolute;
		left: 90%;
		transform: translatex(-50%);
		width: 110px;
		height: auto;
		z-index: 2;
		animation: rocketFlight 2s infinite ease-in-out;
		transition: all 0.3s ease-in-out;
	}
	.deno-a {
		position: absolute;
		animation: rocketFlight 2s infinite ease-in-out;
		transition: all 0.3s ease-in-out;
		z-index: 2;
		right: 0;
		max-width: 10%; 
		height: auto; 
		aspect-ratio: 1/1;
	}

	@keyframes rocketFlight {
		0% {
			bottom: 0%;
		}
		50% {
			bottom: 10%;
		}
		100% {
			bottom: 0%;
		}
	}

	@keyframes upAndDown {
		0% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-10%);
		}
		100% {
			transform: translateY(0%);
		}
	}
</style>
