---
import Layout from '../../layouts/Layout.astro';
import TemplateGuard from '../../components/templates/TemplateGuard.astro';
/*
 * Atelier — Studio / agency portfolio template.
 * Editorial, lots of whitespace, case grid + numbered process.
 */

const cases = [
	{ n: '01', client: 'Forma Health', tag: 'Brand + product', year: '2026' },
	{ n: '02', client: 'Helios Studio', tag: 'Identity', year: '2025' },
	{ n: '03', client: 'Ribeira Café', tag: 'Packaging + e-commerce', year: '2025' },
	{ n: '04', client: 'Maré', tag: 'App + design system', year: '2024' },
	{ n: '05', client: 'Northbound', tag: 'Marketing site', year: '2024' },
	{ n: '06', client: 'Vector One', tag: 'Brand refresh', year: '2024' },
];

const process = [
	{ n: '01', t: 'Discovery', d: 'Two weeks of conversation, audit and listening. We end with one page of strategy — not fifty.' },
	{ n: '02', t: 'Design', d: 'Direction first, then refinement. You see three real options, never six abstract concepts.' },
	{ n: '03', t: 'Build', d: 'Production-grade engineering from week one. No "handoff" gap, no design that breaks at scale.' },
	{ n: '04', t: 'Ship & Hold', d: 'Launch is the start, not the end. Three months of free iterations included on every project.' },
];
---

<Layout title='Atelier · Studio template' description='Studio / agency template — Atelier by Fab Bahiense.'>
	<TemplateGuard />
	<div class='tpl tpl-atelier'>
		<a href='/templates' class='ribbon'>
			← Templates · Atelier <span class='r-sep'>—</span>
			<span class='r-cta'>Want this template?</span>
		</a>

		<header class='tb'>
			<div class='tb-inner'>
				<a href='#' class='brand'>Atelier <span class='dot'>◆</span></a>
				<nav class='tb-nav'>
					<a href='#work'>Work</a>
					<a href='#process'>Process</a>
					<a href='#studio'>Studio</a>
					<a href='#contact'>Contact</a>
				</nav>
				<a href='#contact' class='tb-cta'>Start a project ↗</a>
			</div>
		</header>

		<section class='hero'>
			<p class='eyebrow'>// Independent design studio · est. 2019</p>
			<h1>
				We make <span class='hl'>quiet brands</span><br />
				that get <em-bold>louder</em-bold> over time.
			</h1>
			<div class='hero-meta'>
				<div>
					<span class='eyebrow'>Available</span>
					<p>Q2 / 2026 — 1 spot</p>
				</div>
				<div>
					<span class='eyebrow'>Based</span>
					<p>Rio de Janeiro / remote</p>
				</div>
				<div>
					<span class='eyebrow'>For</span>
					<p>Founders, agencies, in&#8209;house teams</p>
				</div>
			</div>
		</section>

		<!-- Cases grid -->
		<section class='work' id='work'>
			<div class='sec-h'>
				<span class='eyebrow'>// Selected work · 2024 — 2026</span>
				<h2>Six projects, <span class='hl'>one principle:</span> design that ships.</h2>
			</div>
			<div class='case-grid'>
				{cases.map((c) => (
					<a href='#' class='case'>
						<div class='case-thumb' />
						<div class='case-meta'>
							<span class='c-n'>{c.n}</span>
							<div class='c-info'>
								<h3>{c.client}</h3>
								<p>
									<span>{c.tag}</span>
									<span class='sep'>·</span>
									<span>{c.year}</span>
								</p>
							</div>
							<span class='c-arr'>↗</span>
						</div>
					</a>
				))}
			</div>
			<div class='work-foot'>
				<a href='#' class='link'>View the full archive →</a>
			</div>
		</section>

		<!-- Process -->
		<section class='process' id='process'>
			<div class='sec-h left'>
				<span class='eyebrow'>// How we work</span>
				<h2>A simple <span class='hl'>four-step</span> process.</h2>
				<p class='sec-l'>No agency theater. No 80-page decks. Just enough structure to keep momentum and protect quality.</p>
			</div>
			<div class='steps'>
				{process.map((s) => (
					<article class='step'>
						<span class='s-n'>{s.n}</span>
						<div class='s-body'>
							<h3>{s.t}</h3>
							<p>{s.d}</p>
						</div>
					</article>
				))}
			</div>
		</section>

		<!-- Studio -->
		<section class='studio' id='studio'>
			<div class='studio-grid'>
				<div class='studio-copy'>
					<span class='eyebrow'>// The studio</span>
					<h2>Small on purpose.</h2>
					<p>
						We're a two-person studio by design. Every project gets senior attention from the first
						sketch to the last commit. No account managers, no telephone game, no "let me check with
						the team."
					</p>
					<p>
						We take on six to eight projects a year. Each one starts with a conversation, never a
						form.
					</p>
					<a href='#contact' class='link'>Read the manifesto →</a>
				</div>
				<dl class='studio-stats'>
					<div><dt>42</dt><dd>brands shipped</dd></div>
					<div><dt>96%</dt><dd>retention after launch</dd></div>
					<div><dt>2</dt><dd>partners, no payroll</dd></div>
					<div><dt>0</dt><dd>discovery decks</dd></div>
				</dl>
			</div>
		</section>

		<!-- Contact -->
		<section class='contact' id='contact'>
			<span class='eyebrow'>// Let's begin</span>
			<h2>
				Have something <span class='hl'>worth making?</span><br />
				Tell us about it.
			</h2>
			<p class='c-sub'>We answer every email within two business days — usually with a calendar link or a polite no.</p>
			<a href='mailto:hello@atelier.studio' class='c-mail'>hello@atelier.studio →</a>
			<p class='c-foot'>
				or follow along
				<a href='#'>Instagram</a>
				·
				<a href='#'>Are.na</a>
				·
				<a href='#'>Read.cv</a>
			</p>
		</section>

		<footer class='ft'>
			<div class='ft-inner'>
				<a href='#' class='brand'>Atelier <span class='dot'>◆</span></a>
				<p>© 2026 · Independent design studio · Rio de Janeiro</p>
			</div>
		</footer>
	</div>
</Layout>

<style>
	.tpl-atelier {
		--accent: #7c3aed;
		--accent-soft: rgba(124, 58, 237, 0.1);
		--tpl-bg: #fbfafd;
		--tpl-ink: #1a1525;
		--tpl-ink-2: #5b556b;
		--tpl-ink-3: #8e8aa0;
		--tpl-rule: rgba(26, 21, 37, 0.07);
		--tpl-rule-2: rgba(26, 21, 37, 0.14);

		background: var(--tpl-bg);
		color: var(--tpl-ink);
		min-height: 100vh;
	}
	.tpl-atelier .hl {
		color: var(--accent);
	}
	em-bold {
		font-style: normal;
		font-weight: 800;
		background: linear-gradient(120deg, transparent 0 60%, var(--accent-soft) 60% 100%);
		padding: 0 4px;
	}

	.ribbon {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding: 10px 16px;
		background: var(--tpl-ink);
		color: #fff;
		font-family: var(--mono);
		font-size: 12px;
		letter-spacing: 0.04em;
	}
	.ribbon .r-sep {
		opacity: 0.4;
	}
	.ribbon .r-cta {
		color: var(--accent);
		font-weight: 600;
	}

	.tb {
		position: sticky;
		top: 0;
		z-index: 40;
		background: rgba(251, 250, 253, 0.85);
		backdrop-filter: saturate(180%) blur(14px);
		border-bottom: 1px solid var(--tpl-rule);
	}
	.tb-inner {
		max-width: 1240px;
		margin: 0 auto;
		padding: 20px 32px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
	}
	.brand {
		font-weight: 700;
		font-size: 18px;
		letter-spacing: -0.02em;
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: var(--tpl-ink);
	}
	.brand .dot {
		color: var(--accent);
		font-size: 14px;
	}
	.tb-nav {
		display: flex;
		gap: 28px;
		font-size: 14px;
		color: var(--tpl-ink-2);
	}
	.tb-nav a:hover {
		color: var(--accent);
	}
	.tb-cta {
		font-family: var(--mono);
		font-size: 13px;
		color: var(--tpl-ink);
		font-weight: 600;
		border-bottom: 2px solid var(--accent);
		padding-bottom: 2px;
	}
	@media (max-width: 860px) {
		.tb-nav {
			display: none;
		}
	}

	/* Hero */
	.hero {
		max-width: 1240px;
		margin: 0 auto;
		padding: 120px 32px 100px;
	}
	.eyebrow {
		font-family: var(--mono);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.12em;
		color: var(--accent);
		text-transform: uppercase;
		display: block;
		margin-bottom: 24px;
	}
	.hero h1 {
		font-size: clamp(48px, 8vw, 124px);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 0.96;
		max-width: 14ch;
	}
	.hero-meta {
		margin-top: 80px;
		padding-top: 28px;
		border-top: 1px solid var(--tpl-rule);
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 40px;
	}
	.hero-meta div .eyebrow {
		color: var(--tpl-ink-3);
		margin-bottom: 8px;
	}
	.hero-meta div p {
		font-size: 15px;
		color: var(--tpl-ink-2);
	}
	@media (max-width: 780px) {
		.hero-meta {
			grid-template-columns: 1fr;
			gap: 24px;
		}
	}

	/* Section heads */
	.sec-h {
		max-width: 760px;
		margin: 0 auto 64px;
		text-align: center;
	}
	.sec-h.left {
		margin-left: 0;
		text-align: left;
	}
	.sec-h h2 {
		font-size: clamp(36px, 5vw, 64px);
		font-weight: 800;
		letter-spacing: -0.035em;
		line-height: 1.05;
	}
	.sec-h .eyebrow {
		display: block;
		margin-bottom: 18px;
	}
	.sec-l {
		margin-top: 16px;
		font-size: 17px;
		color: var(--tpl-ink-2);
		line-height: 1.55;
		max-width: 60ch;
	}

	/* Cases */
	.work {
		max-width: 1240px;
		margin: 0 auto;
		padding: 100px 32px;
	}
	.case-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 40px 32px;
	}
	.case {
		display: flex;
		flex-direction: column;
		gap: 20px;
		transition: transform 0.35s var(--ease-out-expo);
	}
	.case:hover {
		transform: translateY(-6px);
	}
	.case-thumb {
		aspect-ratio: 5 / 4;
		background: linear-gradient(135deg, #e8e4fe, #d4cffa);
		border-radius: 16px;
		position: relative;
		overflow: hidden;
	}
	.case-thumb::before {
		content: '';
		position: absolute;
		inset: 30% 25% auto auto;
		width: 50px;
		height: 50px;
		border-radius: 50%;
		background: var(--accent);
		opacity: 0.4;
		filter: blur(8px);
	}
	.case-thumb::after {
		content: '';
		position: absolute;
		inset: auto 20% 25% 20%;
		height: 40%;
		background: linear-gradient(180deg, transparent, rgba(26, 21, 37, 0.08));
		border-radius: 8px;
	}
	.case:nth-child(2) .case-thumb {
		background: linear-gradient(135deg, #fef3c7, #fbe07e);
	}
	.case:nth-child(3) .case-thumb {
		background: linear-gradient(135deg, #fce7f3, #f9c4e3);
	}
	.case:nth-child(4) .case-thumb {
		background: linear-gradient(135deg, #dcfce7, #b8f5cb);
	}
	.case:nth-child(5) .case-thumb {
		background: linear-gradient(135deg, #ffe8de, #ffd4c2);
	}
	.case:nth-child(6) .case-thumb {
		background: linear-gradient(135deg, #cffafe, #a1f3f9);
	}
	.case-meta {
		display: grid;
		grid-template-columns: auto 1fr auto;
		gap: 16px;
		align-items: center;
	}
	.c-n {
		font-family: var(--mono);
		font-size: 13px;
		color: var(--tpl-ink-3);
	}
	.c-info h3 {
		font-size: 22px;
		font-weight: 700;
		letter-spacing: -0.015em;
	}
	.c-info p {
		font-size: 13px;
		color: var(--tpl-ink-3);
		margin-top: 4px;
	}
	.c-info .sep {
		margin: 0 8px;
		opacity: 0.4;
	}
	.c-arr {
		font-size: 22px;
		color: var(--tpl-ink-3);
		transition: color 0.25s, transform 0.25s;
	}
	.case:hover .c-arr {
		color: var(--accent);
		transform: translate(4px, -4px);
	}
	.work-foot {
		margin-top: 48px;
		text-align: center;
	}
	.link {
		font-family: var(--mono);
		font-size: 14px;
		color: var(--accent);
		font-weight: 600;
		border-bottom: 1px solid var(--accent);
		padding-bottom: 2px;
	}
	@media (max-width: 780px) {
		.case-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Process */
	.process {
		max-width: 1240px;
		margin: 0 auto;
		padding: 100px 32px;
	}
	.steps {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 8px;
	}
	.step {
		padding: 36px 32px;
		display: flex;
		gap: 24px;
		align-items: flex-start;
		border-top: 1px solid var(--tpl-rule);
	}
	.step:nth-child(1),
	.step:nth-child(2) {
		border-top: none;
	}
	.s-n {
		font-family: var(--mono);
		font-size: 56px;
		font-weight: 300;
		line-height: 1;
		color: var(--accent);
		opacity: 0.8;
	}
	.s-body h3 {
		font-size: 24px;
		font-weight: 700;
		letter-spacing: -0.015em;
		margin-bottom: 8px;
	}
	.s-body p {
		font-size: 15px;
		color: var(--tpl-ink-2);
		line-height: 1.6;
	}
	@media (max-width: 780px) {
		.steps {
			grid-template-columns: 1fr;
		}
		.step {
			border-top: 1px solid var(--tpl-rule);
			padding: 28px 0;
		}
		.step:nth-child(1) {
			border-top: none;
		}
		.step:nth-child(2) {
			border-top: 1px solid var(--tpl-rule);
		}
	}

	/* Studio */
	.studio {
		background: linear-gradient(135deg, #f3f0ff, #e6ddfe);
		padding: 120px 32px;
		border-radius: 32px;
		max-width: 1240px;
		margin: 0 auto 100px;
	}
	.studio-grid {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 64px;
		max-width: 1100px;
		margin: 0 auto;
		align-items: center;
	}
	.studio-copy h2 {
		font-size: clamp(40px, 5.5vw, 72px);
		font-weight: 800;
		letter-spacing: -0.035em;
		line-height: 1.02;
		margin: 12px 0 24px;
	}
	.studio-copy p {
		font-size: 17px;
		color: var(--tpl-ink-2);
		line-height: 1.7;
		margin-bottom: 16px;
	}
	.studio-stats {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 28px 32px;
	}
	.studio-stats div {
		padding-top: 14px;
		border-top: 2px solid var(--accent);
	}
	.studio-stats dt {
		font-size: 44px;
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1;
		color: var(--tpl-ink);
	}
	.studio-stats dd {
		font-family: var(--mono);
		font-size: 12px;
		letter-spacing: 0.08em;
		color: var(--tpl-ink-3);
		margin-top: 8px;
		text-transform: uppercase;
	}
	@media (max-width: 780px) {
		.studio-grid {
			grid-template-columns: 1fr;
			gap: 40px;
		}
	}

	/* Contact */
	.contact {
		max-width: 880px;
		margin: 0 auto;
		padding: 120px 32px;
		text-align: center;
	}
	.contact h2 {
		font-size: clamp(40px, 6vw, 80px);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1.05;
		max-width: 16ch;
		margin: 14px auto 0;
	}
	.c-sub {
		margin: 28px auto;
		font-size: 17px;
		color: var(--tpl-ink-2);
		max-width: 50ch;
		line-height: 1.55;
	}
	.c-mail {
		font-size: clamp(22px, 3vw, 32px);
		font-weight: 700;
		color: var(--accent);
		letter-spacing: -0.02em;
		transition: gap 0.25s;
		display: inline-block;
		border-bottom: 2px solid var(--accent);
		padding-bottom: 4px;
	}
	.c-foot {
		margin-top: 56px;
		font-family: var(--mono);
		font-size: 13px;
		color: var(--tpl-ink-3);
	}
	.c-foot a {
		color: var(--tpl-ink);
		margin: 0 4px;
		border-bottom: 1px solid currentColor;
	}
	.c-foot a:hover {
		color: var(--accent);
	}

	/* Footer */
	.ft {
		padding: 32px;
		border-top: 1px solid var(--tpl-rule);
	}
	.ft-inner {
		max-width: 1240px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 14px;
	}
	.ft p {
		font-size: 12px;
		font-family: var(--mono);
		color: var(--tpl-ink-3);
	}
</style>
