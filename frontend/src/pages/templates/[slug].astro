<script>
	// Accent colour picker: repaints the wireframe via a CSS custom property
	// on the preview element. No fake content — only the accent stripes shift.
	const preview = document.getElementById('tpl-preview') as HTMLElement | null;
	if (preview) {
		document.querySelectorAll<HTMLButtonElement>('.picker .sw').forEach((btn) => {
			btn.addEventListener('click', () => {
				const c = btn.dataset.c;
				if (!c) return;
				preview.style.setProperty('--tpl-accent', c);
				document.querySelectorAll('.picker .sw').forEach((b) => b.classList.remove('is-active'));
				btn.classList.add('is-active');
			});
		});
	}
</script>
