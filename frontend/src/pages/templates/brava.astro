---
import Layout from '../../layouts/Layout.astro';
import TemplateGuard from '../../components/templates/TemplateGuard.astro';
/*
 * Brava — E-commerce / limited drop template.
 * Bold, product-first. Countdown, product grid, lookbook, newsletter.
 */

const products = [
	{ n: '001', name: 'Vento Tee', price: 'R$ 189', tag: 'OG', sold: false },
	{ n: '002', name: 'Maré Hoodie', price: 'R$ 459', tag: 'NEW', sold: false },
	{ n: '003', name: 'Costa Cap', price: 'R$ 149', tag: '', sold: false },
	{ n: '004', name: 'Sol Tote', price: 'R$ 119', tag: 'LAST', sold: false },
	{ n: '005', name: 'Brisa Crewneck', price: 'R$ 389', tag: '', sold: true },
	{ n: '006', name: 'Ouro Socks', price: 'R$ 79', tag: '', sold: false },
];
---

<Layout title='Brava · Limited drop template' description='E-commerce / drop template — Brava by Fab Bahiense.'>
	<TemplateGuard />
	<div class='tpl tpl-brava'>
		<a href='/templates' class='ribbon'>
			← Templates · Brava <span class='r-sep'>—</span>
			<span class='r-cta'>Want this template?</span>
		</a>

		<!-- Announcement ticker -->
		<div class='ticker'>
			<div class='ticker-track'>
				{Array.from({ length: 2 }).map(() => (
					<div class='ticker-row' aria-hidden={Array.from({ length: 2 }).indexOf(2) === 1 ? 'true' : undefined}>
						<span>★ Drop 03 / Verão · live until June 30 ★ free shipping over R$ 300 ★ pre-orders ship in 7 days ★ only 250 pieces per drop ★ Drop 03 / Verão · live until June 30 ★ free shipping over R$ 300 ★</span>
					</div>
				))}
			</div>
		</div>

		<header class='tb'>
			<div class='tb-inner'>
				<nav class='tb-nav left'>
					<a href='#shop'>Shop</a>
					<a href='#lookbook'>Lookbook</a>
					<a href='#story'>Story</a>
				</nav>
				<a href='#' class='brand'>BRAVA</a>
				<div class='tb-actions'>
					<a href='#'>Search</a>
					<a href='#'>Account</a>
					<a href='#' class='cart'>Cart <span class='cart-c'>2</span></a>
				</div>
			</div>
		</header>

		<!-- Hero -->
		<section class='hero'>
			<div class='hero-grid'>
				<div class='hero-l'>
					<p class='eyebrow'>// Drop 03 / Verão · 250 pieces · live now</p>
					<h1>
						The summer<br /><em-bold>that ends</em-bold><br /><span class='hl'>too fast.</span>
					</h1>
					<p class='hero-sub'>
						Six pieces, made in Brazil, shipped worldwide. When they're gone, they're gone — we
						don't restock.
					</p>
					<div class='counter' id='counter' aria-label='Time until drop ends'>
						<div><span class='c-v' id='cd-d'>14</span><span class='c-l'>days</span></div>
						<div><span class='c-v' id='cd-h'>06</span><span class='c-l'>hrs</span></div>
						<div><span class='c-v' id='cd-m'>23</span><span class='c-l'>min</span></div>
						<div><span class='c-v' id='cd-s'>00</span><span class='c-l'>sec</span></div>
					</div>
					<a href='#shop' class='btn-acc'>Shop the drop →</a>
				</div>
				<div class='hero-r'>
					<div class='hero-img i-1'></div>
					<div class='hero-img i-2'></div>
					<div class='hero-img i-3'></div>
				</div>
			</div>
		</section>

		<!-- Product grid -->
		<section class='shop' id='shop'>
			<div class='shop-h'>
				<span class='eyebrow'>// The drop · 06 pieces</span>
				<h2>Take your pick.</h2>
			</div>
			<div class='prod-grid'>
				{products.map((p) => (
					<a href='#' class={`prod ${p.sold ? 'is-sold' : ''}`}>
						<div class='prod-img'>
							{p.tag && <span class='p-tag'>{p.tag}</span>}
							{p.sold && <span class='p-sold'>SOLD OUT</span>}
						</div>
						<div class='prod-meta'>
							<span class='p-n'>{p.n}</span>
							<div>
								<h3>{p.name}</h3>
								<p>{p.price}</p>
							</div>
						</div>
					</a>
				))}
			</div>
		</section>

		<!-- Lookbook -->
		<section class='lookbook' id='lookbook'>
			<div class='lb-grid'>
				<div class='lb-1'></div>
				<div class='lb-2'></div>
				<div class='lb-3'></div>
				<div class='lb-4'></div>
			</div>
			<p class='lb-caption'>
				<span class='eyebrow'>// Lookbook</span>
				Shot in Búzios, March 2026. Photography by Maré Studio.
			</p>
		</section>

		<!-- Story -->
		<section class='story' id='story'>
			<div class='story-inner'>
				<span class='eyebrow'>// The story</span>
				<h2>
					Small batches. <span class='hl'>Made on purpose.</span>
				</h2>
				<p>
					Brava is a Brazilian label run by two friends. We design, sample and stitch each piece in
					Rio, then ship from a single warehouse in São Paulo.
				</p>
				<p>
					We release four drops a year, 200–300 pieces each. No restocks, no seasons, no Black
					Friday. When a piece sells out it's gone — and we move on to the next thing.
				</p>
				<a href='#' class='link'>Read more →</a>
			</div>
		</section>

		<!-- Newsletter -->
		<section class='news'>
			<div class='news-inner'>
				<h2>Be first <span class='hl'>next drop.</span></h2>
				<p>One email per drop. Never marketing — just the link, the date, and a thank you.</p>
				<form class='news-form' onsubmit='event.preventDefault()'>
					<input type='email' placeholder='you@email.com' aria-label='Your email' required />
					<button type='submit' class='btn-acc'>Notify me</button>
				</form>
			</div>
		</section>

		<footer class='ft'>
			<div class='ft-inner'>
				<a href='#' class='brand'>BRAVA</a>
				<div class='ft-cols'>
					<div>
						<h4>Shop</h4>
						<a href='#'>The drop</a><a href='#'>Archive</a><a href='#'>Gift cards</a>
					</div>
					<div>
						<h4>Help</h4>
						<a href='#'>Shipping</a><a href='#'>Returns</a><a href='#'>Size guide</a>
					</div>
					<div>
						<h4>Brava</h4>
						<a href='#'>Story</a><a href='#'>Press</a><a href='#'>Contact</a>
					</div>
				</div>
			</div>
			<div class='ft-bot'>
				<span>© 2026 Brava · Made in Brazil, shipped from São Paulo.</span>
				<span>Instagram · TikTok</span>
			</div>
		</footer>
	</div>
</Layout>

<script>
	// Tiny countdown demo (visual only — ends on a date 14 days out)
	const target = new Date(Date.now() + 14 * 24 * 3600 * 1000 + 6 * 3600 * 1000 + 23 * 60 * 1000).getTime();
	const els = {
		d: document.getElementById('cd-d'),
		h: document.getElementById('cd-h'),
		m: document.getElementById('cd-m'),
		s: document.getElementById('cd-s'),
	};
	const tick = () => {
		const diff = Math.max(0, target - Date.now());
		const d = Math.floor(diff / 86400000);
		const h = Math.floor((diff % 86400000) / 3600000);
		const m = Math.floor((diff % 3600000) / 60000);
		const s = Math.floor((diff % 60000) / 1000);
		if (els.d) els.d.textContent = String(d).padStart(2, '0');
		if (els.h) els.h.textContent = String(h).padStart(2, '0');
		if (els.m) els.m.textContent = String(m).padStart(2, '0');
		if (els.s) els.s.textContent = String(s).padStart(2, '0');
	};
	tick();
	setInterval(tick, 1000);
</script>

<style>
	.tpl-brava {
		--accent: #059669;
		--accent-soft: rgba(5, 150, 105, 0.1);
		--tpl-bg: #f7fbf9;
		--tpl-ink: #0e1a14;
		--tpl-ink-2: #4a5b53;
		--tpl-ink-3: #7d8e85;
		--tpl-rule: rgba(14, 26, 20, 0.08);
		--tpl-rule-2: rgba(14, 26, 20, 0.16);

		background: var(--tpl-bg);
		color: var(--tpl-ink);
		min-height: 100vh;
	}
	.tpl-brava .hl {
		color: var(--accent);
	}
	em-bold {
		font-style: normal;
		text-decoration: underline;
		text-decoration-color: var(--accent);
		text-decoration-thickness: 6px;
		text-underline-offset: -2px;
		text-decoration-skip-ink: none;
	}

	.ribbon {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding: 10px 16px;
		background: var(--tpl-ink);
		color: #fff;
		font-family: var(--mono);
		font-size: 12px;
		letter-spacing: 0.04em;
	}
	.ribbon .r-sep {
		opacity: 0.4;
	}
	.ribbon .r-cta {
		color: var(--accent);
		font-weight: 600;
	}

	/* Ticker */
	.ticker {
		background: var(--accent);
		color: #fff;
		padding: 9px 0;
		overflow: hidden;
		font-family: var(--mono);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.05em;
	}
	.ticker-track {
		display: flex;
		gap: 0;
		width: max-content;
		animation: tick 28s linear infinite;
	}
	.ticker-row {
		white-space: nowrap;
		padding-right: 40px;
	}
	@keyframes tick {
		to {
			transform: translateX(-50%);
		}
	}

	.eyebrow {
		font-family: var(--mono);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent);
		display: block;
		margin-bottom: 20px;
	}

	/* Topbar */
	.tb {
		position: sticky;
		top: 0;
		z-index: 40;
		background: rgba(247, 251, 249, 0.9);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid var(--tpl-rule);
	}
	.tb-inner {
		max-width: 1240px;
		margin: 0 auto;
		padding: 18px 32px;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 24px;
	}
	.brand {
		font-weight: 900;
		font-size: 22px;
		letter-spacing: -0.02em;
		text-align: center;
		color: var(--tpl-ink);
	}
	.tb-nav {
		display: flex;
		gap: 24px;
		font-family: var(--mono);
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--tpl-ink-2);
	}
	.tb-nav.left a:hover {
		color: var(--accent);
	}
	.tb-actions {
		display: flex;
		justify-content: flex-end;
		gap: 18px;
		font-family: var(--mono);
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--tpl-ink-2);
	}
	.cart {
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}
	.cart-c {
		background: var(--accent);
		color: #fff;
		padding: 2px 7px;
		border-radius: 999px;
		font-size: 10px;
	}
	@media (max-width: 780px) {
		.tb-nav,
		.tb-actions a:not(.cart) {
			display: none;
		}
		.tb-inner {
			grid-template-columns: 1fr auto;
		}
	}

	/* Hero */
	.hero {
		max-width: 1240px;
		margin: 0 auto;
		padding: 80px 32px 60px;
	}
	.hero-grid {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 56px;
		align-items: center;
	}
	.hero-l h1 {
		font-size: clamp(56px, 8.5vw, 132px);
		font-weight: 900;
		letter-spacing: -0.045em;
		line-height: 0.92;
	}
	.hero-sub {
		margin-top: 28px;
		font-size: 18px;
		color: var(--tpl-ink-2);
		line-height: 1.55;
		max-width: 44ch;
	}
	.counter {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 12px;
		margin-top: 32px;
		max-width: 420px;
		padding: 18px;
		background: #fff;
		border: 2px solid var(--tpl-ink);
		border-radius: 12px;
	}
	.counter div {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.c-v {
		font-family: var(--mono);
		font-size: 28px;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		line-height: 1;
	}
	.c-l {
		font-family: var(--mono);
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--tpl-ink-3);
		margin-top: 4px;
	}
	.btn-acc {
		display: inline-flex;
		padding: 14px 28px;
		margin-top: 28px;
		background: var(--tpl-ink);
		color: #fff;
		border-radius: 0;
		font-family: var(--mono);
		font-size: 13px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		border: 2px solid var(--tpl-ink);
		transition: all 0.2s;
	}
	.btn-acc:hover {
		background: var(--accent);
		border-color: var(--accent);
		transform: translate(-3px, -3px);
		box-shadow: 3px 3px 0 0 var(--tpl-ink);
	}

	.hero-r {
		display: grid;
		grid-template-columns: 1fr 1fr;
		grid-template-rows: 1fr 1fr;
		gap: 12px;
		aspect-ratio: 1;
	}
	.hero-img {
		background: linear-gradient(135deg, #dcfce7, #b8f5cb);
		border-radius: 8px;
	}
	.hero-img.i-1 {
		grid-row: 1 / 3;
		background: linear-gradient(135deg, var(--accent), #0d9b6a);
	}
	.hero-img.i-2 {
		background: linear-gradient(135deg, #b8f5cb, #86efac);
	}
	.hero-img.i-3 {
		background: linear-gradient(135deg, #fef3c7, #fbe07e);
	}
	@media (max-width: 900px) {
		.hero-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Shop */
	.shop {
		max-width: 1240px;
		margin: 0 auto;
		padding: 80px 32px;
	}
	.shop-h {
		margin-bottom: 40px;
	}
	.shop-h h2 {
		font-size: clamp(40px, 6vw, 80px);
		font-weight: 900;
		letter-spacing: -0.04em;
		line-height: 1;
	}
	.prod-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 28px 20px;
	}
	.prod {
		display: flex;
		flex-direction: column;
		gap: 12px;
		transition: transform 0.3s;
	}
	.prod:hover {
		transform: translateY(-4px);
	}
	.prod-img {
		aspect-ratio: 4 / 5;
		background: linear-gradient(135deg, #ecfdf5, #d1fae5);
		border-radius: 4px;
		position: relative;
		overflow: hidden;
	}
	.prod:nth-child(2) .prod-img {
		background: linear-gradient(135deg, #fef3c7, #fbe07e);
	}
	.prod:nth-child(3) .prod-img {
		background: linear-gradient(135deg, #e0f2fe, #bae6fd);
	}
	.prod:nth-child(4) .prod-img {
		background: linear-gradient(135deg, #fce7f3, #f9c4e3);
	}
	.prod:nth-child(5) .prod-img {
		background: linear-gradient(135deg, #f3f4f6, #d1d5db);
	}
	.prod:nth-child(6) .prod-img {
		background: linear-gradient(135deg, #fef3c7, #f59e0b);
	}
	.prod.is-sold .prod-img {
		filter: grayscale(1) opacity(0.6);
	}
	.p-tag {
		position: absolute;
		top: 12px;
		left: 12px;
		background: var(--tpl-ink);
		color: #fff;
		font-family: var(--mono);
		font-size: 10px;
		font-weight: 700;
		padding: 4px 8px;
		letter-spacing: 0.08em;
	}
	.p-sold {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%) rotate(-6deg);
		background: var(--tpl-ink);
		color: #fff;
		font-family: var(--mono);
		font-weight: 700;
		font-size: 14px;
		letter-spacing: 0.1em;
		padding: 6px 14px;
	}
	.prod-meta {
		display: flex;
		gap: 12px;
		align-items: flex-start;
	}
	.p-n {
		font-family: var(--mono);
		font-size: 11px;
		color: var(--tpl-ink-3);
		padding-top: 4px;
	}
	.prod-meta h3 {
		font-size: 17px;
		font-weight: 700;
		letter-spacing: -0.01em;
	}
	.prod-meta p {
		font-family: var(--mono);
		font-size: 14px;
		color: var(--accent);
		font-weight: 600;
		margin-top: 4px;
	}
	@media (max-width: 780px) {
		.prod-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	/* Lookbook */
	.lookbook {
		max-width: 1240px;
		margin: 60px auto 0;
		padding: 0 32px;
	}
	.lb-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		grid-template-rows: 240px 240px;
		gap: 12px;
	}
	.lb-1 {
		grid-row: 1 / 3;
		background: linear-gradient(135deg, #0d9b6a, #047857);
	}
	.lb-2 {
		background: linear-gradient(135deg, #fef3c7, #fbe07e);
	}
	.lb-3 {
		background: linear-gradient(135deg, #fce7f3, #f9c4e3);
	}
	.lb-4 {
		grid-column: 1 / 3;
		background: linear-gradient(135deg, #ecfdf5, #6ee7b7);
		grid-row: auto;
	}
	.lb-caption {
		margin-top: 18px;
		font-family: var(--mono);
		font-size: 12px;
		color: var(--tpl-ink-3);
		display: flex;
		gap: 16px;
		align-items: center;
		flex-wrap: wrap;
	}
	.lb-caption .eyebrow {
		margin-bottom: 0;
		color: var(--accent);
	}

	/* Story */
	.story {
		max-width: 720px;
		margin: 100px auto 0;
		padding: 0 32px;
	}
	.story-inner h2 {
		font-size: clamp(36px, 5.5vw, 64px);
		font-weight: 900;
		letter-spacing: -0.035em;
		line-height: 1.05;
		margin-bottom: 24px;
	}
	.story-inner p {
		font-size: 19px;
		color: var(--tpl-ink-2);
		line-height: 1.65;
		margin-bottom: 18px;
	}
	.link {
		font-family: var(--mono);
		font-size: 13px;
		color: var(--accent);
		font-weight: 700;
		border-bottom: 2px solid var(--accent);
		padding-bottom: 2px;
	}

	/* Newsletter */
	.news {
		max-width: 1240px;
		margin: 100px auto 0;
		padding: 80px 32px;
		background: var(--tpl-ink);
		border-radius: 12px;
		color: #fff;
	}
	.news-inner {
		max-width: 640px;
		margin: 0 auto;
		text-align: center;
	}
	.news h2 {
		font-size: clamp(36px, 5vw, 56px);
		font-weight: 900;
		letter-spacing: -0.035em;
		line-height: 1.05;
	}
	.news .hl {
		color: #6ee7b7;
	}
	.news p {
		margin: 18px auto 32px;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.7);
		max-width: 50ch;
	}
	.news-form {
		display: flex;
		gap: 0;
		max-width: 460px;
		margin: 0 auto;
	}
	.news-form input {
		flex: 1;
		padding: 14px 18px;
		border: 2px solid rgba(255, 255, 255, 0.15);
		background: rgba(255, 255, 255, 0.05);
		color: #fff;
		font: inherit;
		font-size: 14px;
		border-right: none;
	}
	.news-form input::placeholder {
		color: rgba(255, 255, 255, 0.4);
	}
	.news-form input:focus {
		outline: none;
		border-color: var(--accent);
	}
	.news-form button {
		margin: 0;
		border: 2px solid var(--accent);
		background: var(--accent);
		color: #fff;
	}
	.news-form button:hover {
		transform: none;
		box-shadow: none;
		background: #047857;
		border-color: #047857;
	}

	/* Footer */
	.ft {
		margin-top: 80px;
		padding: 60px 32px 24px;
		border-top: 1px solid var(--tpl-rule);
	}
	.ft-inner {
		max-width: 1240px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 2fr 3fr;
		gap: 56px;
	}
	.ft-cols {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
	}
	.ft h4 {
		font-family: var(--mono);
		font-size: 11px;
